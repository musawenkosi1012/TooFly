# =================================================================
# TOOTFLY MASTER NATIVE ENVIRONMENT TEMPLATE (.env.example)
# =================================================================

# --- CORE SERVICE (Port 8000) ---
PORT=8000
PROJECT_NAME="TooFly Core Engine"
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
SECRET_KEY=generate_a_random_32_character_string
ALGORITHM=HS256
INTERNAL_API_KEY=generate_a_random_uuid_for_internal_auth
PAYMENT_SERVICE_URL=http://localhost:9000

# Seeding (Optional)
ADMIN_EMAIL=admin@toofly.com
ADMIN_PASSWORD=mUSA21005

# --- PAYMENT SERVICE (Port 9000) ---
# PORT is 9000 for this service
PAYNOW_INTEGRATION_ID=your_id
PAYNOW_INTEGRATION_KEY=your_key
PAYNOW_RETURN_URL=http://localhost:3000/success
PAYNOW_RESULT_URL=http://localhost:9000/api/v1/payments/callback
CORE_SERVICE_URL=http://localhost:8000
# INTERNAL_API_KEY (Shared with Core)
PAYNOW_MERCHANT_EMAIL=your_paynow_registered_email

# --- FRONTEND (Port 3000) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
